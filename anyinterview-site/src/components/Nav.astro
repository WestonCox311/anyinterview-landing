---
---
<nav class="hero-nav">
  <a href="#" class="wordmark" id="homeLink">AnyInterview<span class="dot">.to</span></a>
  <div class="nav-links">
    <a href="#">Product</a>
    <a href="#">For</a>
    <a href="#">Pricing</a>
  </div>
  <div class="nav-cta">
    <a href="#" class="sign-in">Sign in</a>
    <a href="#" class="start">Start an interview</a>
  </div>
</nav>
<style>
  nav.hero-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px clamp(20px, 5vw, 56px) 0;
    font-size: 14px;
  }

  .wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  .wordmark .dot {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }

  .nav-links {
    display: flex;
    gap: 40px;
    color: var(--ink-soft);
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav-links a:hover { color: var(--accent); }

  .nav-cta { display: flex; align-items: center; gap: 24px; }
  .nav-secondary {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav-secondary:hover { color: var(--accent); }
  .sign-in {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .sign-in:hover { color: var(--accent); }

  .start {
    background: var(--ink);
    color: var(--paper);
    padding: 9px 18px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    transition: transform 0.2s ease, background 0.2s ease;
    font-size: 14px;
  }
  .start:hover { background: var(--accent); transform: translateY(-1px); }

  @media (max-width: 720px) {
    .nav-links { display: none; }
  }
</style>
