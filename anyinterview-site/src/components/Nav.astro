---
---
<nav class="hero-nav">
  <a href="#" class="wordmark" id="homeLink">AnyInterview<span class="dot">.to</span></a>
  <div class="nav-links">
    <a href="#forWhom">Use Cases</a>
    <a href="#how">How It Works</a>
    <a href="#trust">Trust</a>
    <a href="#faq">FAQ</a>
  </div>
  <div class="nav-cta">
    <a href="#" class="start" data-action="open-demo">Book a Demo</a>
  </div>
</nav>
<style>
  nav.hero-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 28px clamp(20px, 5vw, 56px) 0;
    font-size: 14px;
  }

  .wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  .wordmark .dot {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    color: var(--ink-soft);
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .nav-links a:hover { color: var(--accent); }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 24px;
    justify-content: flex-end;
  }
  .sign-in {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .sign-in:hover { color: var(--accent); }

  .start {
    background: var(--ink);
    color: var(--paper);
    padding: 9px 18px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    transition: transform 0.2s ease, background 0.2s ease;
    font-size: 14px;
    white-space: nowrap;
  }
  .start:hover { background: var(--accent); transform: translateY(-1px); }

  @media (max-width: 1060px) {
    nav.hero-nav { grid-template-columns: auto 1fr auto; gap: 0 20px; }
    .nav-links { gap: 18px; font-size: 13px; justify-content: center; }
  }
  @media (max-width: 780px) {
    nav.hero-nav { grid-template-columns: 1fr auto; }
    .nav-links { display: none; }
  }
</style>
