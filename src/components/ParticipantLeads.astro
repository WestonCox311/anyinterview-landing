const chipColors: Record<string, string> = {
  active: '#1d3557',
  passive: '#5b6478',
  closed: '#9ba3b3',
  preseed: '#5b6478',
  seed: '#2a4a7c',
  seriesa: '#1d3557',
};

const avatarColors = [
  '#d8e0ec','#ede8da','#ecf0f6','#f9f6ee','#d6cfbf'
];

function initials(name: string): string {
  return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
}

function renderChip(text: string, type: string): string {
  const color = chipColors[type] ?? '#5b6478';
  return `<span class="db-chip" style="color:${color};border-color:${color}22;background:${color}0d">${text}</span>`;
}

function renderCell(cell: string | { text: string; chip?: string; mono?: boolean }, idx: number, colIdx: number): string {
  if (typeof cell === 'string') {
    if (cell === 'invite') {
      return `<div class="db-cell db-cell-action"><button class="db-invite-btn" data-action="open-demo">Invite →</button></div>`;
    }
    return `<div class="db-cell">${cell}</div>`;
  }

  if (colIdx === 0) {
    const color = avatarColors[idx % avatarColors.length];
    const init = initials(cell.text);
    return `<div class="db-cell db-cell-name">
      <span class="db-avatar" style="background:${color}">${init}</span>
      <span>${cell.text}</span>
    </div>`;
  }

  if (cell.chip) {
    return `<div class="db-cell">${renderChip(cell.text, cell.chip)}</div>`;
  }

  if (cell.mono) {
    return `<div class="db-cell"><span class="db-mono">${cell.text}</span></div>`;
  }

  return `<div class="db-cell">${cell.text}</div>`;
}

function renderVertical(key: string): void {
  const data = verticals[key];
  if (!data) return;

  const countEl = document.getElementById('dbCount');
  const filterEl = document.getElementById('dbFilterTag');
  const totalEl = document.getElementById('dbTotal');
  const headEl = document.getElementById('dbHead');
  const bodyEl = document.getElementById('dbBody');

  if (countEl) countEl.textContent = data.count;
  if (filterEl) filterEl.textContent = data.filter;
  if (totalEl) totalEl.textContent = data.total;

  if (headEl) {
    headEl.innerHTML = data.cols.map(col =>
      `<div class="db-th">${col}</div>`
    ).join('');
  }

  if (bodyEl) {
    bodyEl.innerHTML = data.rows.map((row, idx) =>
      `<div class="db-row">${row.map((cell, colIdx) => renderCell(cell, idx, colIdx)).join('')}</div>`
    ).join('');

    // Wire invite buttons
    bodyEl.querySelectorAll<HTMLButtonElement>('[data-action="open-demo"]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        (window as any).openDemoModal?.();
      });
    });
  }
}

// Init
renderVertical('hiring');

document.querySelectorAll<HTMLElement>('.leads-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.leads-tab').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');
    renderVertical(tab.dataset.vertical ?? 'hiring');
  });
});
</script>

<style>
  .leads-section {
    position: relative;
    z-index: 2;
    padding: clamp(80px, 12vh, 140px) clamp(20px, 5vw, 56px);
    background: var(--accent-soft);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .leads-inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .leads-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto clamp(40px, 6vh, 72px);
  }

  .leads-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 22px;
  }
  .leads-eyebrow::before, .leads-eyebrow::after {
    content: "";
    width: 22px;
    height: 1px;
    background: var(--rule);
  }

  .leads-title {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(34px, 4.8vw, 60px);
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .leads-title em {
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }

  .leads-sub {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* Vertical tabs */
  .leads-tabs {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .leads-tab {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-mute);
    background: transparent;
    border: 1px solid var(--rule);
    padding: 7px 16px;
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .leads-tab:hover {
    color: var(--ink);
    border-color: var(--ink-soft);
    background: var(--white);
  }
  .leads-tab.active {
    color: var(--white);
    background: var(--ink);
    border-color: var(--ink);
  }

  /* Database card */
  .db-card {
    background: var(--paper-cool);
    border: 1px solid var(--rule);
    border-radius: 14px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .db-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--rule);
    gap: 16px;
    flex-wrap: wrap;
  }

  .db-toolbar-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .db-record-count {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }

  .db-filter-tag {
    font-size: 11.5px;
    color: var(--ink-mute);
    background: var(--accent-faint);
    border: 1px solid var(--accent-soft);
    padding: 3px 10px;
    border-radius: 100px;
    font-family: 'JetBrains Mono', monospace;
  }

  .db-toolbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .db-search {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: var(--ink-faint);
    background: var(--field-bg);
    border: 1px solid var(--rule);
    padding: 6px 12px;
    border-radius: 8px;
    min-width: 180px;
    pointer-events: none;
    user-select: none;
  }
  .db-search svg {
    width: 13px;
    height: 13px;
    stroke: var(--ink-faint);
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  .db-filter-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12.5px;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--rule);
    padding: 6px 12px;
    border-radius: 8px;
    pointer-events: none;
  }
  .db-filter-btn svg {
    width: 13px;
    height: 13px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }

  /* Table */
  .db-table {
    overflow-x: auto;
  }

  .db-thead {
    display: grid;
    padding: 0 20px;
    border-bottom: 1px solid var(--rule);
    background: var(--paper-warm);
  }

  .db-th {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    padding: 10px 8px;
  }

  .db-tbody {
    /* rows */
  }

  .db-row {
    display: grid;
    padding: 0 20px;
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s ease;
  }
  .db-row:last-child { border-bottom: none; }
  .db-row:hover { background: var(--accent-faint); }

  .db-cell {
    padding: 13px 8px;
    font-size: 13px;
    color: var(--ink-soft);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .db-cell-name {
    display: flex;
    align-items: center;
    gap: 9px;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
  }

  .db-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9.5px;
    font-weight: 600;
    color: var(--ink-soft);
    flex-shrink: 0;
  }

  .db-mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-mute);
  }

  .db-chip {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 100px;
    border: 1px solid;
    white-space: nowrap;
  }

  .db-cell-action {
    justify-content: flex-end;
  }

  .db-invite-btn {
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-faint);
    border: 1px solid var(--accent-soft);
    padding: 5px 12px;
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.18s ease;
    white-space: nowrap;
  }
  .db-invite-btn:hover {
    background: var(--accent-soft);
    transform: translateY(-1px);
  }

  /* Table grid — 7 cols with action col narrow */
  .db-thead, .db-row {
    grid-template-columns: 1.4fr 1.6fr 1fr 1.4fr 1fr 1fr 90px;
    min-width: 760px;
  }

  /* Footer */
  .db-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    border-top: 1px solid var(--rule);
    background: var(--paper-warm);
  }

  .db-footer-note {
    font-size: 12px;
    color: var(--ink-faint);
  }

  .db-footer-link {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .db-footer-link:hover { color: var(--accent-bright); text-decoration: underline; }

  @media (max-width: 720px) {
    .db-search { display: none; }
    .db-filter-btn { display: none; }
    .db-filter-tag { display: none; }
  }
</style>
