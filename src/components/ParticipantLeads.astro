---
<section class="leads-section" id="participants">
  <div class="leads-inner">

    <div class="leads-header">
      <span class="leads-eyebrow">Participant sourcing</span>
      <h2 class="leads-title">No contacts? <em>We'll find them.</em></h2>
      <p class="leads-sub">
        AnyInterview connects you with pre-qualified participants across every interview type —
        vetted, available, and matched to your exact use case. Send a link directly from the studio.
      </p>
    </div>

    <div class="leads-tabs" role="tablist" aria-label="Interview verticals">
      <button class="leads-tab active" data-vertical="hiring" role="tab" aria-selected="true">Hiring</button>
      <button class="leads-tab" data-vertical="discovery" role="tab" aria-selected="false">Customer discovery</button>
      <button class="leads-tab" data-vertical="research" role="tab" aria-selected="false">User research</button>
      <button class="leads-tab" data-vertical="legal" role="tab" aria-selected="false">Legal</button>
    </div>

    <div class="db-card">
      <div class="db-toolbar">
        <div class="db-toolbar-left">
          <span class="db-record-count" id="dbCount">847 participants</span>
          <span class="db-filter-tag" id="dbFilterTag">Backend · 5–12 yrs exp · Open to roles</span>
        </div>
        <div class="db-toolbar-right">
          <div class="db-search" aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
            <span>Search participants…</span>
          </div>
          <button class="db-filter-btn" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
            Filters
          </button>
        </div>
      </div>

      <div class="db-table" id="dbTable">
        <div class="db-thead" id="dbHead">
          <!-- populated by JS -->
        </div>
        <div class="db-tbody" id="dbBody">
          <!-- populated by JS -->
        </div>
      </div>

      <div class="db-footer">
        <span class="db-footer-note">Showing 5 of <span id="dbTotal">847</span> matches</span>
        <a href="#" class="db-footer-link" data-action="open-demo">Book a Demo →</a>
      </div>
    </div>

  </div>
</section>

