---
---
<div id="demoModal" class="demo-modal" aria-hidden="true" role="dialog" aria-labelledby="demoModalTitle" aria-modal="true">
  <div class="demo-modal-backdrop"></div>
  <div class="demo-modal-card">
    <button type="button" class="demo-modal-close" aria-label="Close">×</button>
    <form id="demoForm" class="demo-form">
      <h2 id="demoModalTitle">Book a <em>demo.</em></h2>
      <p class="demo-intro">Tell us a little about what you're trying to do — we'll send a private demo link and book a 20-minute walkthrough. We reply within one business day.</p>
      <label><span>Email</span><input type="email" name="email" required placeholder="you@yourdomain.com" autocomplete="email" /></label>
      <label><span>Name</span><input type="text" name="name" required placeholder="Your name" autocomplete="name" /></label>
      <label><span>Company / institution <em>(optional)</em></span><input type="text" name="company" placeholder="Acme Inc." autocomplete="organization" /></label>
      <label><span>What kind of interviews? <em>(optional)</em></span><textarea name="useCase" rows="3" placeholder="Capstone selection, source interviews, hiring, customer discovery…"></textarea></label>
      <input type="text" name="hp_company2" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true">
      <button type="submit" id="demoSubmitBtn" class="demo-submit">Send and book a demo →</button>
      <p class="demo-form-meta">We'll never share your email.</p>
    </form>
    <div id="demoSuccess" class="demo-success" hidden>
      <h3>Thanks — we'll be in touch.</h3>
      <p>Your request landed in our inbox. We'll reply to <strong id="demoSuccessEmail"></strong> within one business day with a private demo link.</p>
      <button type="button" class="demo-modal-close-btn">Close</button>
    </div>
  </div>
</div>

<script>import '../scripts/demo-modal.ts';</script>

<style>
  .demo-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 320ms;
  }
  .demo-modal.open {
    opacity: 1;
    pointer-events: auto;
  }

  .demo-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10,22,40,0.42);
    backdrop-filter: blur(4px);
  }

  .demo-modal-card {
    position: relative;
    z-index: 1;
    background: var(--paper-cool);
    border: 1px solid var(--rule);
    box-shadow: var(--shadow-lg);
    border-radius: 14px;
    width: min(560px, calc(100vw - 32px));
    max-height: calc(100vh - 64px);
    overflow-y: auto;
    padding: 40px;
    transform: translateY(20px);
    transition: transform 320ms cubic-bezier(0.22,1,0.36,1);
  }
  .demo-modal.open .demo-modal-card {
    transform: translateY(0);
  }

  .demo-modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: var(--ink-mute);
    background: transparent;
    border: 1px solid var(--rule);
    transition: background 0.15s ease, color 0.15s ease;
    line-height: 1;
  }
  .demo-modal-close:hover {
    background: var(--paper-warm);
    color: var(--ink);
  }

  .demo-form h2 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .demo-form h2 em {
    font-style: italic;
    color: var(--accent);
  }

  .demo-intro {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 28px;
  }

  .demo-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .demo-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .demo-form label span {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
    text-transform: uppercase;
  }
  .demo-form label span em {
    font-style: normal;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-faint);
  }
  .demo-form input,
  .demo-form textarea {
    background: var(--field-bg);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 14.5px;
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    width: 100%;
  }
  .demo-form input:focus,
  .demo-form textarea:focus {
    border-color: var(--accent-bright);
    background: var(--white);
  }
  .demo-form textarea {
    resize: vertical;
    min-height: 80px;
  }

  .demo-submit {
    background: var(--ink);
    color: var(--paper);
    padding: 12px 24px;
    border-radius: 100px;
    font-weight: 500;
    font-size: 15px;
    width: 100%;
    transition: background 0.2s ease, transform 0.15s ease;
    margin-top: 4px;
  }
  .demo-submit:hover {
    background: var(--accent);
    transform: translateY(-1px);
  }
  .demo-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .demo-form-meta {
    font-size: 12px;
    color: var(--ink-faint);
    text-align: center;
    font-style: italic;
  }

  .demo-success {
    text-align: center;
    padding: 20px 0;
  }
  .demo-success h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .demo-success p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 24px;
  }
  .demo-success strong {
    color: var(--accent);
    font-weight: 500;
  }

  .demo-modal-close-btn {
    background: var(--ink);
    color: var(--paper);
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s ease;
  }
  .demo-modal-close-btn:hover { background: var(--accent); }
</style>
