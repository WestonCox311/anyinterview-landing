---
---
<div class="section-divider"></div>

<section class="how" id="how">
  <div class="how-header">
    <div class="how-eyebrow">How it works</div>
    <h2 class="how-title">
      Any interview, <em>running in 90 seconds.</em>
    </h2>
    <p class="how-sub">From idea to share link in 90 seconds.</p>
  </div>

  <div class="steps">

    <div class="step" data-step="1">
      <div class="step-number"><span class="num-em">0</span>1</div>
      <div class="step-name">Describe</div>
      <div class="step-rule"></div>
      <p class="step-body">
        Tell us what kind of interview you need — in plain language, in chat. <strong>Role, questions, tone, length.</strong> Or start from a template built for your kind of work.
      </p>
      <div class="step-photo" aria-hidden="true">
        <img
          src="/photography/how-it-works-typing/overhead-hands-keyboard.jpg"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <div class="step" data-step="2">
      <div class="step-number"><span class="num-em">0</span>2</div>
      <div class="step-name">Delegate</div>
      <div class="step-rule"></div>
      <p class="step-body">
        Get a link. Send it to anyone, anywhere. They join when it works for them — by <strong>voice, video, or both</strong>, with optional monitoring. The interview happens without you.
      </p>
      <div class="step-vis" aria-hidden="true">
        <div class="vis-link">
          <div class="pill">anyinterview.to/<span style="opacity:0.55">k7m9q4</span></div>
          <div class="arrows"><span>›</span><span>›</span><span>›</span></div>
        </div>
      </div>
    </div>

    <div class="step" data-step="3">
      <div class="step-number"><span class="num-em">0</span>3</div>
      <div class="step-name">Decide</div>
      <div class="step-rule"></div>
      <p class="step-body">
        The interview comes back to you <strong>transcribed, recorded, and summarized</strong> — with the moments that matter already surfaced. Read in five minutes what would have taken an hour to conduct.
      </p>
      <div class="step-photo" aria-hidden="true">
        <img
          src="/photography/how-it-works-debrief/woman-glasses-computer-intently.jpg"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

  </div>

  <div class="how-closing" id="howClosing">
    <p class="closing-line">
      Or fifty places. <span class="em">Or a hundred.</span>
    </p>
    <a href="#" class="cta-primary" id="scrollToHeroBtn">
      Build your first interview
      <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
    <!-- <div class="cta-meta">
      Free to try <span class="dot"></span> No credit card <span class="dot"></span> 90 seconds to share link
    </div> -->
  </div>
</section>

<script>import '../scripts/scroll-reveal.ts';</script>

<style>
  .section-divider {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 56px);
    position: relative;
    z-index: 2;
  }
  .section-divider::before {
    content: "";
    display: block;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--rule) 20%, var(--rule) 80%, transparent);
  }

  section.how {
    position: relative;
    z-index: 2;
    padding: clamp(80px, 14vh, 160px) clamp(20px, 5vw, 56px) clamp(80px, 12vh, 140px);
    max-width: 1240px;
    margin: 0 auto;
  }

  .how-header {
    text-align: center;
    max-width: 780px;
    margin: 0 auto clamp(60px, 9vh, 110px);
  }

  .how-eyebrow {
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 26px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .how-eyebrow::before, .how-eyebrow::after {
    content: "";
    width: 22px; height: 1px;
    background: var(--rule);
  }

  h2.how-title {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(36px, 5.2vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  h2.how-title em {
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }

  .how-sub {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 22px);
    line-height: 1.5;
    color: var(--ink-soft);
    margin-top: 22px;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 56px);
    position: relative;
  }

  .steps::before {
    content: "";
    position: absolute;
    top: 38px;
    left: 12%;
    right: 12%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--rule) 12%, var(--rule) 88%, transparent);
    z-index: 0;
  }

  .step {
    position: relative;
    z-index: 1;
    padding: 0 clamp(8px, 1.5vw, 24px);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .step.in-view { opacity: 1; transform: translateY(0); }
  .step:nth-child(1) { transition-delay: 0s; }
  .step:nth-child(2) { transition-delay: 0.15s; }
  .step:nth-child(3) { transition-delay: 0.30s; }

  .step-number {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(56px, 8vw, 88px);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    background: var(--paper);
    display: inline-block;
    padding: 0 18px;
    margin-left: -18px;
    margin-bottom: 28px;
    position: relative;
  }
  .step-number .num-em {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }

  .step-name {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 30px);
    color: var(--ink);
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }

  .step-rule {
    width: 32px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 18px;
  }

  .step-body {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 32ch;
  }
  .step-body strong {
    color: var(--ink);
    font-weight: 500;
  }

  .step-vis {
    margin-top: 30px;
    height: 120px;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--field-bg);
    padding: 14px;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    position: relative;
  }

  .vis-chat {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 4px 6px;
  }
  .vis-chat .glyph {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--accent-soft);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .vis-chat .glyph::after {
    content: "";
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }
  .vis-chat .typing {
    flex: 1;
    height: 28px;
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: 8px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: var(--ink-soft);
    font-style: italic;
    overflow: hidden;
    white-space: nowrap;
  }
  .vis-chat .typing .text {
    display: inline-block;
    overflow: hidden;
    border-right: 2px solid var(--accent);
    animation: typeText 4s steps(28) infinite;
  }
  .step.in-view .vis-chat .typing .text {
    animation-play-state: running;
  }

  .vis-link {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--ink-soft);
  }
  .vis-link .pill {
    background: var(--white);
    border: 1px solid var(--rule);
    padding: 8px 14px;
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    box-shadow: var(--shadow-sm);
  }
  .vis-link .pill::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #2d8659;
    box-shadow: 0 0 0 3px rgba(45,134,89,0.18);
  }
  .vis-link .arrows {
    display: flex;
    gap: 4px;
    color: var(--ink-faint);
  }
  .vis-link .arrows span {
    animation: pulseArrow 1.4s ease-in-out infinite;
  }
  .vis-link .arrows span:nth-child(2) { animation-delay: 0.15s; }
  .vis-link .arrows span:nth-child(3) { animation-delay: 0.3s; }

  .vis-doc {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    padding: 4px 8px;
  }
  .vis-doc .line {
    height: 8px;
    border-radius: 4px;
    background: var(--rule);
    position: relative;
    overflow: hidden;
  }
  .vis-doc .line.short { width: 50%; }
  .vis-doc .line.med { width: 75%; }
  .vis-doc .line.full { width: 92%; }
  .vis-doc .line.highlight {
    background: var(--accent-soft);
  }
  .vis-doc .line.highlight::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.3;
    animation: scanLine 2.6s ease-in-out infinite;
  }

  /* ── Step photo cards ── */
  .step-photo {
    margin-top: 30px;
    height: 200px;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    border: 1px solid var(--rule);
  }
  .step-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Step 1: warm overhead keyboard — focus on the hands */
  .step[data-step="1"] .step-photo img { object-position: center 45%; }
  /* Step 3: screen-lit face — focus on the glasses/eyes */
  .step[data-step="3"] .step-photo img { object-position: center 18%; }

  .step:hover .step-photo img { transform: scale(1.04); }

  .how-closing {
    margin-top: clamp(60px, 8vh, 100px);
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease 0.45s, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.45s;
  }
  .how-closing.in-view { opacity: 1; transform: translateY(0); }

  .closing-line {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 1.7vw, 24px);
    color: var(--ink-soft);
    margin-bottom: 30px;
  }
  .closing-line .em {
    color: var(--accent);
    font-weight: 400;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ink);
    color: var(--paper);
    padding: 14px 26px;
    border-radius: 100px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.005em;
    transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    box-shadow: var(--shadow-md);
  }
  .cta-primary:hover {
    background: var(--accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg);
  }
  .cta-primary svg {
    width: 16px; height: 16px;
    stroke: currentColor; fill: none; stroke-width: 2.2;
  }

  .cta-meta {
    margin-top: 16px;
    font-size: 12px;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
  }
  .cta-meta .dot {
    display: inline-block;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--ink-faint);
    margin: 0 8px 2px;
    vertical-align: middle;
  }

  @media (max-width: 900px) {
    .steps {
      grid-template-columns: 1fr;
      gap: 56px;
    }
    .steps::before { display: none; }
  }
</style>
