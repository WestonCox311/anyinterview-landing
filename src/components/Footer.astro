        <p class="footer-tag">
          Conduct any structured interview without being in the room.
        </p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
          <a href="#" aria-label="X / Twitter"><svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></a>
          <a href="#" aria-label="Email"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg></a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Use Cases</h4>
        <ul>
          <li><a href="/use-cases/hiring">Hiring &amp; Recruiting</a></li>
          <li><a href="/use-cases/customer-discovery">Customer Discovery</a></li>
          <li><a href="/use-cases/user-research">User Research</a></li>
          <li><a href="/use-cases/audit-compliance">Audit &amp; Compliance</a></li>
          <li><a href="/use-cases/legal-intake">Legal Intake</a></li>
          <li><a href="/use-cases/hr-people">HR &amp; People</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Product</h4>
        <ul>
          <li><a href="/how-it-works">How it works</a></li>
          <li><a href="/templates">Templates</a></li>
          <li><a href="/integrations">Integrations</a></li>
          <li><a href="/changelog">Changelog <span class="badge">New</span></a></li>
          <li><a href="/api">API</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/careers">Careers</a></li>
          <li><a href="/press">Press</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/security">Security &amp; Compliance</a></li>
          <li><a href="/trust">Trust Center</a></li>
          <li><a href="/docs">Documentation</a></li>
          <li><a href="/help">Help Center</a></li>
          <li><a href="/status">Status</a></li>
