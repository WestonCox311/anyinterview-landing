    </div>

    <div class="footer-bottom">
      <div class="footer-mark">© 2026 AnyInterview, Inc.</div>
      <div class="legal">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/cookies">Cookies</a>
        <a href="/dpa">DPA</a>
        <a href="/subprocessors">Subprocessors</a>
