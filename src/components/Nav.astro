---
---
<nav class="hero-nav">
  <a href="/" class="wordmark" id="homeLink"><span class="wordmark-any">Any</span>Interview<span class="dot">.to</span></a>
  <div class="nav-cta">
    <a href="#" class="start" data-action="open-demo">Book a Demo</a>
  </div>
</nav>
<style>
  nav.hero-nav {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 28px clamp(20px, 5vw, 56px) 0;
    font-size: 14px;
  }

  .wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  .wordmark-any {
    color: var(--accent);
  }
  .wordmark .dot {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 24px;
    justify-content: flex-end;
  }

  .start {
    background: var(--accent);
    color: var(--paper);
    padding: 9px 18px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    transition: transform 0.2s ease, background 0.2s ease;
    font-size: 14px;
    white-space: nowrap;
  }
  .start:hover { background: var(--accent-bright); transform: translateY(-1px); }

  @media (max-width: 780px) {
    nav.hero-nav { grid-template-columns: 1fr auto; }
  }
</style>
