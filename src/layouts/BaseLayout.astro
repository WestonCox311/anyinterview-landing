---
import '../styles/tokens.css';
import '../styles/reset.css';
import '../styles/globals.css';
import '../styles/animations.css';
import DemoModal from '../components/DemoModal.astro';

interface Props {
  title?: string;
}
const { title = 'AnyInterview — Conduct interviews without being in the room' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Configure a structured conversation in chat. Send a link. Get it back, transcribed and recorded — ready to use." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body>
    <slot />
    <DemoModal />
  </body>
</html>
