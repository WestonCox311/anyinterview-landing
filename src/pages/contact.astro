---
import InnerLayout from '../layouts/InnerLayout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://anyinterview.to/contact",
      "url": "https://anyinterview.to/contact",
      "name": "Contact — AnyInterview",
      "description": "Get in touch with the AnyInterview team. Book a demo, ask a question, or reach support."
    },
    {
      "@type": "ContactPage",
      "url": "https://anyinterview.to/contact",
      "name": "Contact AnyInterview"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://anyinterview.to"},
        {"@type":"ListItem","position":2,"name":"Contact","item":"https://anyinterview.to/contact"}
      ]
    }
  ]
};
---
<InnerLayout title="Contact — AnyInterview" description="Get in touch with the AnyInterview team. Book a demo, ask a question, or reach support." schema={schema}>

  <section class="ip-hero">
    <div class="ip-hero-inner">
      <span class="ip-eyebrow">Contact</span>
      <h1>We're <em>actually here.</em></h1>
      <p class="ip-hero-sub">We're a small team and we respond personally. Use the right channel and you'll hear from us fast.</p>
    </div>
  </section>

  <section class="ip-section ip-section--alt">
    <div class="ip-section-inner">
      <div class="ip-card-grid ip-card-grid--2">

        <div class="ip-card">
          <div class="ip-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h3>Book a demo</h3>
          <p>See the product live and ask us anything. We run 20-minute demos daily.</p>
          <button class="ip-cta-primary" data-action="open-demo" style="margin-top:16px;">Book a demo →</button>
        </div>

        <div class="ip-card">
          <div class="ip-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <h3>General questions</h3>
          <p>Product questions, partnership inquiries, everything else.</p>
          <a href="mailto:hello@anyinterview.to" class="contact-link">hello@anyinterview.to</a>
        </div>

        <div class="ip-card">
          <div class="ip-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 22V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v14"/><path d="M2 22h20"/><path d="M7 22v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4"/><rect x="14" y="10" width="3" height="3"/><rect x="7" y="10" width="3" height="3"/>
            </svg>
          </div>
          <h3>Press</h3>
          <p>Journalists, researchers, and media inquiries.</p>
          <a href="mailto:press@anyinterview.to" class="contact-link">press@anyinterview.to</a>
        </div>

        <div class="ip-card">
          <div class="ip-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <h3>Support</h3>
          <p>For product help, check our Help Center first — most answers are there.</p>
          <div class="contact-links-row">
            <a href="/help" class="contact-link">Help Center →</a>
            <a href="mailto:support@anyinterview.to" class="contact-link">support@anyinterview.to</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner ip-section-inner--narrow">
      <p class="ip-section-lead">We aim to respond within one business day. For urgent security issues, see our responsible disclosure policy at <a href="/security">/security</a>.</p>
    </div>
  </section>

</InnerLayout>

<style>
  .contact-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .contact-link:hover {
    text-decoration: underline;
  }

  .contact-links-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
</style>
