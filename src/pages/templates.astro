---
import InnerLayout from '../layouts/InnerLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Interview Templates — AnyInterview",
  "url": "https://anyinterview.to/templates",
  "description": "Ready-made structured interview templates for hiring, customer discovery, user research, legal intake, and more.",
  "breadcrumb": {"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://anyinterview.to"},{"@type":"ListItem","position":2,"name":"Templates","item":"https://anyinterview.to/templates"}]},
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Senior Backend Engineer Screen","url":"https://anyinterview.to/templates#hiring"},
      {"@type":"ListItem","position":2,"name":"Customer Discovery: JTBD Framework","url":"https://anyinterview.to/templates#discovery"},
      {"@type":"ListItem","position":3,"name":"Usability Session: Task + Think-Aloud","url":"https://anyinterview.to/templates#research"},
      {"@type":"ListItem","position":4,"name":"Exit Interview: Full Spectrum","url":"https://anyinterview.to/templates#hr"},
      {"@type":"ListItem","position":5,"name":"Legal Intake: Personal Injury","url":"https://anyinterview.to/templates#legal"},
      {"@type":"ListItem","position":6,"name":"Vendor Due Diligence","url":"https://anyinterview.to/templates#audit"}
    ]
  }
};
---
<InnerLayout
  title="Interview Templates — AnyInterview"
  description="Ready-made structured interview templates for hiring, customer discovery, user research, legal intake, and more. Start in 30 seconds."
  schema={schema}
  canonical="https://anyinterview.to/templates"
>

  <section class="ip-hero">
    <div class="ip-hero-inner">
      <p class="ip-eyebrow">Templates</p>
      <h1>Start from a template. <em>Ship in 90 seconds.</em></h1>
      <p class="ip-hero-sub">Every template is a structured conversation built by people who've done hundreds of these interviews. Customize everything — or describe what you need and we'll build it from scratch.</p>
      <div class="ip-cta-row">
        <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
        <a href="/how-it-works" class="ip-cta-secondary">How it works</a>
      </div>
    </div>
  </section>

  <section class="ip-section--alt">
    <div class="ip-section-inner">
      <p class="ip-section-label">Featured Templates</p>
      <h2>Built for the work <em>that actually happens.</em></h2>
      <div class="tpl-filters">
        <span class="tpl-pill tpl-pill--active">All</span>
        <span class="tpl-pill">Hiring</span>
        <span class="tpl-pill">Discovery</span>
        <span class="tpl-pill">Research</span>
        <span class="tpl-pill">HR</span>
        <span class="tpl-pill">Legal</span>
        <span class="tpl-pill">Audit</span>
      </div>
      <div class="ip-card-grid" id="hiring">
        <div class="ip-card tpl-card">
          <div class="tpl-meta">
            <span class="tpl-badge tpl-badge--hiring">Hiring</span>
            <span class="tpl-duration">45 min</span>
          </div>
          <h3>Senior Backend Engineer Screen</h3>
          <p>Voice + video technical screen covering system design, technical depth, and how candidates think about tradeoffs. Proctored. Includes judgment-round questions.</p>
          <a href="#" class="tpl-use" data-action="open-demo">Book a Demo →</a>
        </div>
        <div class="ip-card tpl-card">
          <div class="tpl-meta">
            <span class="tpl-badge tpl-badge--discovery">Discovery</span>
            <span class="tpl-duration">30 min</span>
          </div>
          <h3>Customer Discovery: JTBD Framework</h3>
          <p>Structured Jobs-to-be-Done discovery with probe questions and struggle mapping. Surfaces the circumstances, motivations, and friction that drive switching behavior.</p>
          <a href="#" class="tpl-use" data-action="open-demo">Book a Demo →</a>
        </div>
        <div class="ip-card tpl-card">
          <div class="tpl-meta">
            <span class="tpl-badge tpl-badge--research">UX Research</span>
            <span class="tpl-duration">40 min</span>
          </div>
          <h3>Usability Session: Task + Think-Aloud</h3>
          <p>Moderated-style task observation with branching follow-up probes. Captures hesitation, confusion, and delight — then asks about it.</p>
          <a href="#" class="tpl-use" data-action="open-demo">Book a Demo →</a>
        </div>
        <div class="ip-card tpl-card">
          <div class="tpl-meta">
            <span class="tpl-badge tpl-badge--hr">HR</span>
            <span class="tpl-duration">25 min</span>
          </div>
          <h3>Exit Interview: Full Spectrum</h3>
          <p>Comprehensive exit interview covering role clarity, team dynamics, management relationship, compensation, and likelihood to return or refer.</p>
          <a href="#" class="tpl-use" data-action="open-demo">Book a Demo →</a>
        </div>
        <div class="ip-card tpl-card">
          <div class="tpl-meta">
            <span class="tpl-badge tpl-badge--legal">Legal</span>
            <span class="tpl-duration">20 min</span>
          </div>
          <h3>Legal Intake: Personal Injury</h3>
          <p>Structured intake capturing incident details, medical timeline, insurance information, and prior conditions — everything an attorney needs before the first consultation.</p>
          <a href="#" class="tpl-use" data-action="open-demo">Book a Demo →</a>
        </div>
        <div class="ip-card tpl-card">
          <div class="tpl-meta">
            <span class="tpl-badge tpl-badge--audit">Audit</span>
            <span class="tpl-duration">35 min</span>
          </div>
          <h3>Vendor Due Diligence</h3>
          <p>Third-party vendor assessment covering security posture, compliance certifications, business continuity, and sub-processor chain. Consistent across every vendor.</p>
          <a href="#" class="tpl-use" data-action="open-demo">Book a Demo →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner ip-section-inner--narrow" style="text-align:center">
      <p class="ip-section-label">Build Your Own</p>
      <h2>Don't see what you need? <em>Describe it in chat.</em></h2>
      <p class="ip-section-lead">Tell AnyInterview what kind of interview you need — role, questions, tone, length. The AI builds the structure in seconds. Every interview starts in chat.</p>
      <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
    </div>
  </section>

  <section class="ip-closing">
    <div class="ip-closing-inner">
      <h2>40+ templates. <em>Any interview, 90 seconds.</em></h2>
      <p>Start from a template or describe what you need. We'll have you running interviews today.</p>
      <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
      <p class="ip-closing-meta">Free to try <span class="dot"></span> No credit card <span class="dot"></span> All templates fully customizable</p>
    </div>
  </section>

</InnerLayout>

<style>
  .tpl-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .tpl-pill {
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid var(--rule);
    color: var(--ink-mute);
    cursor: default;
  }
  .tpl-pill--active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .tpl-card { gap: 14px; }
  .tpl-meta { display: flex; align-items: center; gap: 10px; }
  .tpl-badge {
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 3px 9px;
    border-radius: 4px;
    text-transform: uppercase;
  }
  .tpl-badge--hiring { background: #e8f0fb; color: #1d3557; }
  .tpl-badge--discovery { background: #fdf0e6; color: #a0522d; }
  .tpl-badge--research { background: #e9f7ef; color: #1a6b3a; }
  .tpl-badge--hr { background: #f4e8fb; color: #6b2d8a; }
  .tpl-badge--legal { background: #fdf5e6; color: #8a6020; }
  .tpl-badge--audit { background: #fde8e8; color: #8a2020; }
  .tpl-duration { font-size: 12px; color: var(--ink-mute); }
  .tpl-use {
    font-size: 13.5px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    margin-top: auto;
    transition: opacity 0.2s ease;
  }
  .tpl-use:hover { opacity: 0.7; }
</style>
