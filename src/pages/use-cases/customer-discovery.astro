---
import InnerLayout from '../../layouts/InnerLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AI Customer Discovery Interviews",
  "url": "https://anyinterview.to/use-cases/customer-discovery",
  "description": "Run structured customer discovery calls at scale. AnyInterview conducts founder-led discovery interviews — capturing insights, transcribed and ready to use.",
  "breadcrumb": {"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://anyinterview.to"},{"@type":"ListItem","position":2,"name":"Customer Discovery","item":"https://anyinterview.to/use-cases/customer-discovery"}]},
  "about": {"@type":"Service","name":"AI Customer Discovery Interviews","provider":{"@type":"Organization","name":"AnyInterview","url":"https://anyinterview.to"},"serviceType":"AI-powered customer discovery interview automation"}
};
---
<InnerLayout
  title="AI Customer Discovery Interviews — Talk to More Customers | AnyInterview"
  description="Run structured customer discovery calls at scale. AnyInterview conducts your founder-led discovery interviews — capturing insights, transcribed and ready to use."
  schema={schema}
  canonical="https://anyinterview.to/use-cases/customer-discovery"
>

  <section class="ip-hero">
    <div class="ip-hero-inner">
      <p class="ip-eyebrow">Customer Discovery</p>
      <h1>Talk to every customer<br/>who'll take the call. <em>Actually.</em></h1>
      <p class="ip-hero-sub">Discovery compounds. The calendar doesn't. AnyInterview runs your structured discovery calls — in your voice, on your framework — so the insights pile up while you're heads-down building.</p>
      <div class="ip-cta-row">
        <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
        <a href="/templates" class="ip-cta-secondary">Browse discovery templates</a>
      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner">
      <p class="ip-section-label">The Problem</p>
      <h2>You're building on <em>what twelve people told you.</em></h2>
      <p class="ip-section-lead">Every founder knows discovery compounds. The more conversations you have, the better your product decisions. But the conversations don't happen at the pace the decisions need them to.</p>
      <div class="disc-cols">
        <p>A typical early-stage team does 5–15 discovery interviews before a major product decision. That's a sample size driven by calendar availability, not scientific rigor. The insights that would change the direction of the product are sitting with the 40 customers you didn't have time to talk to.</p>
        <p>Consistency is the other problem. When different team members run discovery, you get different questions, different depths, different follow-ups. Pattern detection across 50 interviews requires that the 50 interviews asked the same things. AnyInterview makes that possible without making discovery robotic.</p>
      </div>
    </div>
  </section>

  <section class="ip-section--alt">
    <div class="ip-section-inner">
      <p class="ip-section-label">How It Works</p>
      <h2>Your framework. <em>Their schedule. Your insights.</em></h2>
      <p class="ip-section-lead">Configure your discovery framework in chat — JTBD, Pain-Gain-Struggle, your own. Send links. Get structured transcripts back with pattern-ready summaries.</p>
      <div class="ip-card-grid--4">
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>Founder-voice interviews</h3>
          <p>Conversations that feel personal and direct — not a survey. Participants respond to a voice that sounds like it cares, because it's configured to ask what you actually want to know.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h8"/></svg>
          </div>
          <h3>Custom discovery frameworks</h3>
          <p>Jobs-to-be-Done, Pain-Gain-Struggle, switching narratives — or describe your own approach in chat and we'll structure it. Every template is fully editable.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3>Full transcripts + summaries</h3>
          <p>Every session returns a searchable transcript and an AI-generated insight summary. Key quotes surfaced. Themes extracted. Ready for your affinity map or product doc.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Async by default</h3>
          <p>Participants complete interviews on their schedule — no coordination overhead. Most sessions are completed within 48 hours of the link being sent.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner">
      <p class="ip-section-label">The Compound Effect</p>
      <h2>Discovery at scale <em>surfaces what one-on-one calls miss.</em></h2>
      <p class="ip-section-lead">The signal that changes your roadmap usually lives in interview 30 — not interview 5. Volume turns anecdote into data.</p>
      <div class="ip-card-grid">
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Pattern detection across cohorts</h3>
          <p>When 50 customers all mention the same friction point in different words, AnyInterview finds it. One-on-one calls trained on your memory don't.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Segment by customer type</h3>
          <p>Run separate discovery tracks for different segments — SMB vs. enterprise, power users vs. casual — and compare the insights side by side.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
          </div>
          <h3>Longitudinal tracking</h3>
          <p>Run the same discovery template quarterly. Watch how customer language, pain points, and priorities shift as your market evolves.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-closing">
    <div class="ip-closing-inner">
      <h2>Start your next discovery sprint <em>today.</em></h2>
      <p>Set up a JTBD template in 90 seconds. Send it to your first 20 customers tonight.</p>
      <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
      <p class="ip-closing-meta">Free to try <span class="dot"></span> No credit card <span class="dot"></span> Works with any discovery framework</p>
    </div>
  </section>

</InnerLayout>

<style>
  .disc-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 8px; }
  .disc-cols p { font-size: 16px; line-height: 1.7; color: var(--ink-soft); }
  @media (max-width: 720px) { .disc-cols { grid-template-columns: 1fr; } }
</style>
