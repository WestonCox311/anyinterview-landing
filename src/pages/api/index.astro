---
import InnerLayout from '../../layouts/InnerLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": ["WebPage", "TechArticle"],
  "name": "API Reference — AnyInterview",
  "url": "https://anyinterview.to/api",
  "description": "REST API reference for AnyInterview. Full CRUD for interviews, participants, transcripts, scores, and recordings. OpenAPI 3.1 spec available.",
  "breadcrumb": {"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://anyinterview.to"},{"@type":"ListItem","position":2,"name":"API Reference","item":"https://anyinterview.to/api"}]},
  "about": {
    "@type": "SoftwareApplication",
    "name": "AnyInterview REST API",
    "applicationCategory": "DeveloperApplication"
  }
};

const resources = [
  {
    name: "Interviews",
    endpoint: "/v1/interviews",
    methods: ["GET", "POST", "PATCH", "DELETE"],
    desc: "Create and manage interview sessions. Set questions, configure proctoring, define the participant flow."
  },
  {
    name: "Participants",
    endpoint: "/v1/interviews/{id}/participants",
    methods: ["GET", "POST"],
    desc: "Add participants and retrieve unique session links. Each participant link is single-use by default."
  },
  {
    name: "Transcripts",
    endpoint: "/v1/interviews/{id}/transcript",
    methods: ["GET"],
    desc: "Retrieve the full timestamped transcript once a session is complete. Word-level and speaker-diarized."
  },
  {
    name: "Scores",
    endpoint: "/v1/interviews/{id}/scores",
    methods: ["GET"],
    desc: "Retrieve AI-generated competency scores with quoted evidence from the transcript."
  },
  {
    name: "Recordings",
    endpoint: "/v1/interviews/{id}/recording",
    methods: ["GET"],
    desc: "Get a signed URL to the session recording. URL expires after 1 hour. AES-256 at rest."
  },
  {
    name: "Webhooks",
    endpoint: "/v1/webhooks",
    methods: ["GET", "POST", "DELETE"],
    desc: "Subscribe to interview events. Configurable retry logic with exponential backoff and per-endpoint receipts."
  }
];

const webhookEvents = [
  "interview.created","interview.started","interview.completed",
  "interview.abandoned","transcript.ready","score.ready",
  "recording.ready","participant.consented","follow_up.triggered","error.occurred"
];
---
<InnerLayout
  title="API Reference — AnyInterview"
  description="REST API for AnyInterview. Full CRUD for interviews, participants, transcripts, scores, and recordings. OpenAPI 3.1 spec available for download."
  schema={schema}
  canonical="https://anyinterview.to/api"
>

  <section class="ip-hero">
    <div class="ip-hero-inner">
      <p class="ip-eyebrow">API Reference</p>
      <h1>The AnyInterview API. <em>Build anything on top of it.</em></h1>
      <p class="ip-hero-sub">REST API with full CRUD for interviews, participants, transcripts, scores, and recordings. Ten webhook event types. OpenAPI 3.1 spec included.</p>
      <div class="ip-cta-row">
        <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
        <a href="#resources" class="ip-cta-secondary">Browse endpoints</a>
      </div>
    </div>
  </section>

  <section class="ip-section--alt">
    <div class="ip-section-inner">
      <p class="ip-section-label">Getting Started</p>
      <h2>One base URL. <em>Bearer token auth.</em></h2>
      <div class="api-meta-grid">
        <div class="api-meta-card">
          <p class="api-meta-label">Base URL</p>
          <code class="api-meta-value">https://api.anyinterview.to/v1</code>
        </div>
        <div class="api-meta-card">
          <p class="api-meta-label">Authentication</p>
          <code class="api-meta-value">Authorization: Bearer &lt;API_KEY&gt;</code>
        </div>
        <div class="api-meta-card">
          <p class="api-meta-label">Content Type</p>
          <code class="api-meta-value">Content-Type: application/json</code>
        </div>
        <div class="api-meta-card">
          <p class="api-meta-label">API Version</p>
          <code class="api-meta-value">v1 (current) — versioned in URL</code>
        </div>
      </div>

      <div class="code-block">
        <div class="code-block-header">
          <span class="code-block-label">Example: Create an interview</span>
          <span class="code-block-lang">cURL</span>
        </div>
        <pre><code>{`curl -X POST https://api.anyinterview.to/v1/interviews \\
  -H "Authorization: Bearer $API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "title": "Senior Backend Engineer Screen",
    "duration_minutes": 45,
    "questions": [
      { "text": "Walk me through how you'd design a rate limiter at scale.", "follow_ups": true },
      { "text": "Tell me about a system you've built that you're proud of.", "follow_ups": true }
    ],
    "proctoring": { "browser_lock": true },
    "notify_on_complete": true
  }'`}</code></pre>
      </div>

      <div class="code-block">
        <div class="code-block-header">
          <span class="code-block-label">Response</span>
          <span class="code-block-lang">JSON</span>
        </div>
        <pre><code>{`{
  "id": "iv_01HXYZ123456",
  "status": "draft",
  "share_url": "https://go.anyinterview.to/s/abc123",
  "created_at": "2026-05-05T10:00:00Z"
}`}</code></pre>
      </div>
    </div>
  </section>

  <section class="ip-section" id="resources">
    <div class="ip-section-inner">
      <p class="ip-section-label">Endpoints</p>
      <h2>Six resources. <em>Everything you need.</em></h2>
      <div class="resources-list">
        {resources.map(r => (
          <div class="resource-row">
            <div class="resource-info">
              <h3 class="resource-name">{r.name}</h3>
              <p class="resource-desc">{r.desc}</p>
            </div>
            <div class="resource-right">
              <code class="resource-endpoint">{r.endpoint}</code>
              <div class="resource-methods">
                {r.methods.map(m => (
                  <span class={`method-badge method-badge--${m.toLowerCase()}`}>{m}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ip-section--alt">
    <div class="ip-section-inner">
      <p class="ip-section-label">Webhooks</p>
      <h2>Push events. <em>Any endpoint.</em></h2>
      <p class="ip-section-lead">Subscribe once. We'll POST every event to your endpoint — with configurable retry logic, exponential backoff, and per-endpoint delivery receipts.</p>
      <div class="webhook-grid">
        {webhookEvents.map(evt => (
          <div class="webhook-event"><code>{evt}</code></div>
        ))}
      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner ip-section-inner--narrow" style="text-align:center">
      <p class="ip-section-label">OpenAPI</p>
      <h2>Download the spec. <em>Generate your client.</em></h2>
      <p class="ip-section-lead">The full OpenAPI 3.1 specification is available to download. Import it into Postman, generate a type-safe client in any language, or use it to power your own docs.</p>
      <div class="ip-cta-row" style="justify-content:center">
        <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
        <a href="#" class="ip-cta-secondary" data-action="open-demo">Download OpenAPI spec</a>
      </div>
    </div>
  </section>

  <section class="ip-closing">
    <div class="ip-closing-inner">
      <h2>Start building. <em>Today.</em></h2>
      <p>API keys are available on Pro and Enterprise plans. Book a demo to get access and a sandbox environment.</p>
      <a href="#" class="ip-cta-primary" data-action="open-demo">Book a Demo →</a>
      <p class="ip-closing-meta">REST + Webhooks <span class="dot"></span> OpenAPI 3.1 <span class="dot"></span> Sandbox available</p>
    </div>
  </section>

</InnerLayout>

<style>
  .api-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 40px;
  }
  .api-meta-card {
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 16px 20px;
  }
  .api-meta-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 6px;
  }
  .api-meta-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent);
    background: none;
    padding: 0;
  }

  .code-block {
    background: #1a1a2e;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .code-block-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .code-block-label { font-size: 12px; color: rgba(255,255,255,0.5); font-weight: 500; }
  .code-block-lang {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .code-block pre {
    margin: 0;
    padding: 20px;
    overflow-x: auto;
  }
  .code-block code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
    color: #c8d3f5;
    background: none;
    padding: 0;
    white-space: pre;
  }

  .resources-list { display: flex; flex-direction: column; gap: 0; }
  .resource-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    padding: clamp(24px, 4vh, 40px) 0;
    border-bottom: 1px solid var(--rule);
    align-items: center;
  }
  .resource-row:last-child { border-bottom: none; }
  .resource-name {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }
  .resource-desc { font-size: 14.5px; color: var(--ink-soft); line-height: 1.6; max-width: 480px; }
  .resource-right { text-align: right; display: flex; flex-direction: column; gap: 10px; align-items: flex-end; }
  .resource-endpoint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 10px;
    border-radius: 5px;
    white-space: nowrap;
  }
  .resource-methods { display: flex; gap: 6px; }
  .method-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.03em;
  }
  .method-badge--get { background: #e9f7ef; color: #1a6b3a; }
  .method-badge--post { background: #e8f0fb; color: #1d3557; }
  .method-badge--patch { background: #fdf5e6; color: #8a6020; }
  .method-badge--delete { background: #fde8e8; color: #8a2020; }

  .webhook-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin-top: 32px;
  }
  .webhook-event {
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 10px 12px;
  }
  .webhook-event code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    background: none;
    padding: 0;
  }

  @media (max-width: 900px) {
    .api-meta-grid { grid-template-columns: 1fr; }
    .resource-row { grid-template-columns: 1fr; gap: 16px; }
    .resource-right { text-align: left; align-items: flex-start; }
    .webhook-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .webhook-grid { grid-template-columns: 1fr; }
  }
</style>
