---
import InnerLayout from '../../layouts/InnerLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AI Hiring Interviews — Screen More Candidates Without More Time",
  "url": "https://anyinterview.to/for/hiring",
  "description": "Run structured first-round interviews at any scale. AnyInterview conducts voice + video screens in your voice — EEOC-compliant, proctored, and transcribed.",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://anyinterview.to"},
      {"@type":"ListItem","position":2,"name":"Hiring & Recruiting","item":"https://anyinterview.to/for/hiring"}
    ]
  },
  "about": {
    "@type": "Service",
    "name": "AI Hiring Interviews",
    "provider": {"@type":"Organization","name":"AnyInterview","url":"https://anyinterview.to"},
    "serviceType": "AI-powered structured hiring interviews",
    "description": "Conduct first-round hiring screens at scale — voice and video, EEOC-compliant, proctored."
  }
};
---
<InnerLayout
  title="AI Hiring Interviews — Screen More Candidates Without More Time | AnyInterview"
  description="Run structured first-round interviews at any scale. AnyInterview conducts voice + video screens in your voice — EEOC-compliant, proctored, and fully transcribed."
  schema={schema}
  canonical="https://anyinterview.to/for/hiring"
>

  <section class="ip-hero">
    <div class="ip-hero-inner">
      <p class="ip-eyebrow">Hiring &amp; Recruiting</p>
      <h1>You have 200 candidates.<br/>Time to talk to <em>twenty.</em></h1>
      <p class="ip-hero-sub">The other 180 aren't less qualified — they're running out of your bandwidth. AnyInterview conducts your first-round screens at any scale, in your voice, on your criteria.</p>
      <div class="ip-cta-row">
        <a href="#" class="ip-cta-primary" data-action="open-demo">Book a demo →</a>
        <a href="/security" class="ip-cta-secondary">Security &amp; compliance</a>
      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner">
      <p class="ip-section-label">The Problem</p>
      <h2>The bottleneck isn't your judgment. <em>It's your calendar.</em></h2>
      <p class="ip-section-lead">Recruiting teams lose great candidates to speed. The first conversation is supposed to be a filter — instead it becomes the constraint.</p>
      <div class="problem-cols">
        <p>The average recruiter can meaningfully screen 8–12 candidates per day. At 200 applicants, that's a three-week backlog before anyone gets a first call. Half your best candidates take another offer in that window. The other half get a rushed 20-minute call that doesn't surface what they're actually capable of.</p>
        <p>EEOC compliance adds another layer: every candidate needs to go through the same process, asked the same questions in the same order. In practice, that rarely happens. Interview quality varies by recruiter, by day, by how much coffee they've had. AnyInterview eliminates the variance.</p>
      </div>
    </div>
  </section>

  <section class="ip-section--alt">
    <div class="ip-section-inner">
      <p class="ip-section-label">How It Works</p>
      <h2>Your interview. <em>At any scale.</em></h2>
      <p class="ip-section-lead">Configure your screen once. Send links to every candidate. Get structured transcripts and scores back — ready to rank.</p>
      <div class="ip-card-grid--4">
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><path d="M12 2a3 3 0 013 3v7a3 3 0 01-6 0V5a3 3 0 013-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8"/></svg>
          </div>
          <h3>Voice + video screening</h3>
          <p>Real-time adaptive conversations — not preset video questions into the void. Follow-up probes respond to what the candidate actually says.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3>Proctored technical assessments</h3>
          <p>Browser-lock mode, activity monitoring, and session continuity tracking for engineering hires. No surveillance theater — just honest signal.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3>EEOC-compliant question flows</h3>
          <p>Every candidate hears the same questions in the same order. Structured scoring rubrics mean every evaluation is defensible.</p>
        </div>
        <div class="ip-card">
          <div class="ip-card-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
          </div>
          <h3>Multilingual support</h3>
          <p>Conduct screens in the candidate's preferred language. Transcripts delivered in English. Built for global hiring programs.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-section">
    <div class="ip-section-inner">
      <p class="ip-section-label">What Changes</p>
      <h2>Remove the bottleneck. <em>See what happens.</em></h2>
      <div class="results-grid">
        <div class="result-item">
          <div class="result-num">10×</div>
          <div class="result-label">more first-round screens per week, same recruiting headcount</div>
        </div>
        <div class="result-item">
          <div class="result-num">60%</div>
          <div class="result-label">faster time-to-first-interview for candidates who apply</div>
        </div>
        <div class="result-item">
          <div class="result-num">100%</div>
          <div class="result-label">of candidates evaluated on the same structured criteria</div>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-section--alt">
    <div class="ip-section-inner ip-section-inner--narrow">
      <p class="ip-section-label">Common Questions</p>
      <h2>What people ask <em>before they start.</em></h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Is AI-conducted interviewing legal?</button>
          <div class="faq-a"><p>Yes, in the jurisdictions where our customers operate. Like any hiring tool, the legal question is about how you use it — not the technology itself. AnyInterview's EEOC-compliant question flows and structured scoring rubrics are specifically designed to reduce, not introduce, discriminatory risk. Consult your employment counsel for jurisdiction-specific guidance.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Does this replace human judgment in hiring?</button>
          <div class="faq-a"><p>No. AnyInterview handles the first-round screen — the structured conversation that qualifies candidates for further consideration. Your team makes the final decision. Think of it as expanding your capacity for due diligence, not removing humans from the loop.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How does AnyInterview avoid introducing bias?</button>
          <div class="faq-a"><p>Structured interviews are one of the best-validated bias-reduction tools in hiring research. Every candidate gets the same questions in the same order, evaluated against the same rubric. Our scoring doesn't factor in voice tone, accent, or anything other than the content of responses — and we're transparent about what the model does and doesn't assess.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How does proctoring work?</button>
          <div class="faq-a"><p>Proctoring is optional and configured per template. In browser-lock mode, candidates can't switch tabs or open new windows without triggering a logged event. We capture activity metadata — not keylogging or ambient video surveillance. Everything is disclosed to the candidate before the interview begins.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="ip-closing">
    <div class="ip-closing-inner">
      <h2>Screen your first 50 candidates <em>this week.</em></h2>
      <p>Set up your first interview in 90 seconds. No credit card required.</p>
      <a href="#" class="ip-cta-primary" data-action="open-demo">Book a demo →</a>
      <p class="ip-closing-meta">Free to try <span class="dot"></span> No credit card <span class="dot"></span> 90 seconds to first interview</p>
    </div>
  </section>

</InnerLayout>

<style>
  .problem-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 8px;
  }
  .problem-cols p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-soft);
  }
  @media (max-width: 720px) {
    .problem-cols { grid-template-columns: 1fr; }
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 14px;
    overflow: hidden;
    margin-top: 16px;
  }
  .result-item {
    background: var(--paper);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .result-num {
    font-family: 'Fraunces', serif;
    font-size: 64px;
    font-weight: 300;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .result-label {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 20ch;
  }
  @media (max-width: 720px) {
    .results-grid { grid-template-columns: 1fr; }
  }

  .faq-list { display: flex; flex-direction: column; gap: 0; margin-top: 8px; }
  .faq-item { border-bottom: 1px solid var(--rule); }
  .faq-q {
    width: 100%;
    text-align: left;
    padding: 20px 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-q::after { content: "+"; font-size: 20px; font-weight: 300; color: var(--ink-mute); flex-shrink: 0; }
  .faq-item.open .faq-q::after { content: "−"; }
  .faq-a { display: none; padding-bottom: 20px; }
  .faq-item.open .faq-a { display: block; }
  .faq-a p { font-size: 15px; line-height: 1.65; color: var(--ink-soft); }
</style>
<script>import '../../scripts/faq-accordion.ts';</script>
